# Copy this file to .env and fill in your real tokens.
# Never commit your real .env file.

# Hugging Face token for gated models such as DINOv3.
HF_TOKEN=your_huggingface_token_here

# Google Drive folder URL used by the folder downloader.
BDC2026_DRIVE_URL=https://drive.google.com/drive/folders/1Wkn2KazyHsSqBQnONkI98SnN--k3gAT7

# Optional: Google Drive file URL for a single zipped dataset.
# Recommended when gdown folder download fails on many individual images.
BDC2026_ZIP_URL=https://drive.google.com/file/d/your_zip_file_id/view?usp=sharing
BDC2026_ZIP_PATH=./BDC2026.zip

# Local dataset path.
# Use ./BDC2026 on Linux servers/local machines.
# Use /content/BDC2026 only on Google Colab.
BDC2026_DATA_ROOT=./BDC2026

# Output paths.
BDC2026_OUTPUT_DIR=./outputs_dinov3_lora
BDC2026_EDA_OUTPUT_DIR=./eda_outputs
